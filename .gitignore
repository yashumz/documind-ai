# ── Secrets — NEVER commit these ──────────────────────────
.env
*.pem
*.key
*_accessKeys.csv

# ── Python ────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/
.uv/

# ── Uploads (stored in S3, not git) ───────────────────────
uploads/
*.pdf
*.docx
*.xlsx
*.jpg
*.png
*.jpeg

# ── Test files (not production code) ──────────────────────
test_sample.pdf
test_image.jpg
create_test_pdf.py

# ── ML model cache (huge files, auto-downloaded) ──────────
# These are downloaded automatically on first run
# No need to commit them — adds hundreds of MB to repo
.cache/
*.onnx
*.safetensors
*.bin

# ── Node / Frontend ───────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local

# ── OS files ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────
.cursor/
.vscode/
*.swp